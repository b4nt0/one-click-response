{
  "timeZone": "Etc/UTC",
  "dependencies": {},
  "exceptionLogging": "STACKDRIVER",
  "runtimeVersion": "V8",
  "oauthScopes": [
    "https://www.googleapis.com/auth/gmail.addons.execute",
    "https://www.googleapis.com/auth/gmail.addons.current.message.metadata",
    "https://www.googleapis.com/auth/gmail.addons.current.action.compose",
    "https://www.googleapis.com/auth/script.external_request",
    "https://www.googleapis.com/auth/userinfo.email",
    "openid"
  ],
  "urlFetchWhitelist": [
    "https://one-click-response.web.app/",
    "https://one-click-response.firebaseapp.com/"
  ],
  "addOns": {
    "common": {
      "name": "One-click Response",
      "logoUrl": "https://www.gstatic.com/images/icons/material/system/1x/reply_black_24dp.png",
      "openLinkUrlPrefixes": [
        "https://one-click-response.web.app/",
        "https://one-click-response.firebaseapp.com/"
      ]
    },
    "gmail": {
      "composeTrigger": {
        "selectActions": [
          {
            "text": "Add response buttons",
            "runFunction": "onComposeTrigger"
          }
        ],
        "draftAccess": "METADATA"
      },
      "contextualTriggers": [
        {
          "unconditional": {},
          "onTriggerFunction": "onMessageOpen"
        }
      ]
    }
  }
}
