rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function ownsCampaign(campaignId) {
      return get(/databases/$(database)/documents/campaigns/$(campaignId)).data.user_id
        == request.auth.uid;
    }

    function canAccessButton(data) {
      return (data.campaign_id != null && ownsCampaign(data.campaign_id))
        || (data.campaign_id == null && data.user_id == request.auth.uid);
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    match /campaigns/{campaignId} {
      allow read, create, update, delete: if isSignedIn()
        && resource == null
          ? request.resource.data.user_id == request.auth.uid
          : resource.data.user_id == request.auth.uid;
    }

    match /response_buttons/{buttonId} {
      allow read, delete: if isSignedIn() && canAccessButton(resource.data);
      allow create: if isSignedIn() && canAccessButton(request.resource.data);
      allow update: if isSignedIn()
        && canAccessButton(resource.data)
        && canAccessButton(request.resource.data);
    }

    match /responses/{responseId} {
      allow read, write: if false;
    }

    match /deduplication/{emailId} {
      allow read, write: if false;
    }
  }
}
